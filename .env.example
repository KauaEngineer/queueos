# ============================================
# Redis (broker de filas)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# PostgreSQL (persistência de logs/snapshots)
# ============================================
DATABASE_URL="postgresql://postgres:queueos@localhost:5432/queueos?schema=public"

# ============================================
# Workers
# ============================================
WORKER_CONCURRENCY=10
MAX_RETRIES=3
JOB_TIMEOUT_MS=30000

# ============================================
# Dashboard
# ============================================
DASHBOARD_PORT=3001
DASHBOARD_SECRET=trocar-esse-secret-em-producao

# ============================================
# Alertas (Sprint 6)
# ============================================
ALERT_WEBHOOK_URL=
